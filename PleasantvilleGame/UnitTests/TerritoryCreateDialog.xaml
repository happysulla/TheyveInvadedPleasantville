<Window x:Class="PleasantvilleGame.TerritoryCreateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Create Territory Dialog" Height="300" Width="800">
   <Grid Name="myGrid" HorizontalAlignment="Center" Width="800" Margin="0,0,0,20">
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="40*"/>
         <RowDefinition Height="40*"/>
         <RowDefinition Height="40*"/>
         <RowDefinition Height="40*"/>
         <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
         <ColumnDefinition/>
         <ColumnDefinition/>
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Center" Orientation="Horizontal">
         <Label Width="120" Content="Choose a name:"/>
         <TextBox x:Name="myTextBoxName" Margin="0,4,-1,0" VerticalAlignment="Top" Width="412"/>
      </StackPanel>
      <Label Grid.Row="2" Grid.Column="0" HorizontalAlignment="Left" Width="94" VerticalAlignment="Center" Height="26" Margin="12,0,0,0">Choose a type:</Label>
      <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Center" Orientation="Horizontal">
         <Grid>
            <Grid.RowDefinitions>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Name="myStackPanelTerritory" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" Orientation="Horizontal">
               <RadioButton GroupName="A" Padding="0,0,0,0" Width="87" Height="26" Content="A" IsEnabled="true" />
               <RadioButton GroupName="A" Padding="0,0,0,0" Width="81" Height="26" Content="B" IsEnabled="true" />
               <RadioButton GroupName="A" Padding="0,0,0,0" Width="73" Height="26" Content="C" IsEnabled="true" />
               <RadioButton GroupName="A" Padding="0,0,0,0" Width="73" Height="26" Content="D" IsEnabled="true" />
               <RadioButton GroupName="A" Padding="0,0,0,0" Width="73" Height="26" Content="E" IsEnabled="true" />
            </StackPanel>
         </Grid>
      </StackPanel>
      <Label Grid.Row="3" Grid.Column="0" HorizontalAlignment="Left" Width="94" VerticalAlignment="Center" Height="26" Margin="12,0,0,0">Choose a Parent:</Label>
      <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Center" Orientation="Horizontal" Width="357">
         <RadioButton Name="myRadioButtonMain" GroupName="B" Padding="0,0,0,0" Width="87" Height="26" Content="Main" />
         <RadioButton Name="myRadioButtonHelper" GroupName="B" Padding="0,0,0,0" Width="81" Height="26" Content="Helper" />
      </StackPanel>
      <Button Grid.Row="5" HorizontalAlignment="Center" Margin="0,13,0,0" Click="OkButton_Click" Width="70" Height="20" VerticalAlignment="Top">OK</Button>
      <Button Grid.Row="5" Grid.Column="1" HorizontalAlignment="Center" Margin="0,13,0,0" IsCancel="True" Width="70" Height="20" VerticalAlignment="Top">Cancel</Button>
   </Grid>
</Window>
