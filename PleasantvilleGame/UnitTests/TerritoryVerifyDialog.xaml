<Window x:Class="PleasantvilleGame.TerritoryVerifyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Verify Territory Dialog" Height="300" Width="1500">
   <Grid HorizontalAlignment="Center" Width="1500"  Margin="0,0,0,20">
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="40*"/>
         <RowDefinition Height="40*"/>
         <RowDefinition Height="40*"/>
         <RowDefinition Height="40*"/>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
         <ColumnDefinition/>
         <ColumnDefinition/>
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Center" Orientation="Horizontal">
         <Label Width="120" Content="Name:"/>
         <TextBox x:Name="myTextBoxName" Margin="0,4,-1,0" VerticalAlignment="Top" Width="412"/>
      </StackPanel>
      <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Center" Orientation="Horizontal">
         <Label Width="120" Content="Choose a subname:"/>
         <TextBox x:Name="myTextBoxSubname" Margin="0,4,-1,0" VerticalAlignment="Top" Width="312"/>
      </StackPanel>
      <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Center" Orientation="Horizontal" Width="357">
         <RadioButton Name="myRadioButtonMain" GroupName="B" Padding="0,0,0,0" Width="87" Height="26" Content="Main" IsChecked="True" />
         <RadioButton Name="myRadioButtonHelper" GroupName="B" Padding="0,0,0,0" Width="81" Height="26" Content="Helper" />
      </StackPanel>
      <Button Grid.Row="6" x:Name="myButtonOk" HorizontalAlignment="Center" Margin="0,13,0,0" Click="OkButton_Click" Width="70" Height="20" VerticalAlignment="Top">OK</Button>
      <Button Grid.Row="6" Grid.Column="1" HorizontalAlignment="Center" Margin="0,13,0,0" IsCancel="True" Width="70" Height="20" VerticalAlignment="Top">Cancel</Button>
   </Grid>
</Window>
