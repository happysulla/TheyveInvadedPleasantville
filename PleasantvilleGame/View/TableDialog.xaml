<Window x:Name="myTableDialog" x:Class="PleasantvilleGame.TableDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        HorizontalContentAlignment="Center" 
        VerticalContentAlignment="Center" 
        UseLayoutRounding="True" 
        WindowStartupLocation="CenterScreen" 
        ShowInTaskbar="False" 
        Topmost="True" 
        Cursor="Arrow" 
        ResizeMode="CanResizeWithGrip" 
        VerticalAlignment="Center" 
        HorizontalAlignment="Center" 
        Loaded="TableDialog_Loaded" 
        SizeChanged="TableDialog_SizeChanged" >
   <ScrollViewer Name="myScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Margin="0,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Top">
      <FlowDocumentScrollViewer Name="myFlowDocumentScrollViewer" BorderBrush="#FF151414" Cursor="Arrow" HorizontalAlignment="Center" VerticalAlignment="Center" VerticalScrollBarVisibility="Disabled" >
         <FlowDocument xmlns='http://schemas.microsoft.com/winfx/2006/xaml/presentation' Name='myFlowDocument'  >
            <Paragraph>Flow Document</Paragraph>
         </FlowDocument>
      </FlowDocumentScrollViewer>
   </ScrollViewer>
</Window>
