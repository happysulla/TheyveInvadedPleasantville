<Window x:Class="PleasantvilleGame.HostGameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Host Game"
        Width="360"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,8" VerticalAlignment="Center" Text="Session Name:" />
        <TextBox Grid.Row="0" Grid.Column="1" Name="SessionNameTextBox" Margin="0,0,0,8" MinWidth="220" Text="Pleasantville Session" />

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,8" VerticalAlignment="Center" Text="Port:" />
        <TextBox Grid.Row="1" Grid.Column="1" Name="PortTextBox" Margin="0,0,0,8" Text="50051" />

        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,12" TextWrapping="Wrap">
            The first scaffold hosts the Alien side on this computer and publishes a LAN join code for the Town player.
        </TextBlock>

        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="80" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click">OK</Button>
            <Button Width="80" IsCancel="True">Cancel</Button>
        </StackPanel>
    </Grid>
</Window>
