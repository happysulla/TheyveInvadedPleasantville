<UserControl x:Class="PleasantvilleGame.EventViewerRandomMovement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PleasantvilleGame"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
   <Grid Name="myGrid" MinWidth="500" MaxWidth="500" Background="#FFB9EA9E" >
      <Grid.ColumnDefinitions>
         <ColumnDefinition Name="myColDef1" Width="1*"/>
         <ColumnDefinition Width="1*"/>
         <ColumnDefinition Width="1*"/>
         <ColumnDefinition Width="1*"/>
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto" ></RowDefinition>
         <RowDefinition Height="Auto"></RowDefinition>
         <RowDefinition Height="Auto"></RowDefinition>
         <RowDefinition Height="Auto"></RowDefinition>
         <RowDefinition Height="Auto"></RowDefinition>
         <RowDefinition Height="Auto"></RowDefinition>
         <RowDefinition Height="Auto"></RowDefinition>
         <RowDefinition Height="Auto"></RowDefinition>
         <RowDefinition Height="Auto"></RowDefinition>
         <RowDefinition Height="Auto"></RowDefinition>
         <RowDefinition Height="Auto"></RowDefinition>
      </Grid.RowDefinitions>
      <StackPanel Grid.Row="0" Grid.ColumnSpan="4" Orientation="Horizontal">
         <TextBlock Name="myTextBlockHeader" Text=" Random Movement" FontWeight="Bold" FontFamily='Georgia' FontSize="24" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,0"/>
         <Button Name="my63" Content='r6.3' FontFamily='Courier New' FontSize='12' Margin="5,0,0,0" Height="14" Click="ButtonRule_Click" Visibility="Visible"/>
         <Button Name="myR1621" Content='Townspeople' FontFamily='Courier New' FontSize='12' Margin="5,0,0,0" Height="14" Click="ButtonRule_Click" Visibility="Visible"/>
         <Button Name="myR1622" Content='Target Building' FontFamily='Courier New' FontSize='12' Margin="5,0,0,0" Height="14" Click="ButtonRule_Click" Visibility="Visible"/>
      </StackPanel>
      <Rectangle Grid.Row="1" Grid.ColumnSpan="4" Margin="5" Height="1" Fill="Black"/>
      <TextBlock Grid.Row="2" Grid.ColumnSpan="4" Name="myTextBlockInstructions" FontFamily='Georgia' FontSize="16" VerticalAlignment="Bottom"  HorizontalAlignment="Left" Margin="2,0,0,5" TextWrapping="Wrap">
        Rolled four times on the Townspeople and Target Building tables to deteremine which four townspeople move and their destinations. 
      </TextBlock>
      <StackPanel Grid.Row="3" Grid.ColumnSpan="4" Name="myStackPanelAssignable" DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Left" Margin="5,0,0,0">
            <Rectangle  Height="42" Width="42" Stroke="Black" />
        </StackPanel>
      <Rectangle Grid.Row="4" Grid.ColumnSpan="4" Margin="5" Height="1" Fill="Black"/>
      <!--Table Header Row-->
      <TextBlock Grid.Row="5" Grid.Column="0" FontFamily='Georgia' FontSize="12" VerticalAlignment="Center"  HorizontalAlignment="Center" Margin="0,5,0,10" Name="myTextBlock0">Townperson</TextBlock>
      <TextBlock Grid.Row="5" Grid.Column="1" FontFamily='Georgia' FontSize="12" VerticalAlignment="Center"  HorizontalAlignment="Center" Margin="0,5,0,10" Name="myTextBlock1">Tied Up/Unc/KIA?</TextBlock>
      <TextBlock Grid.Row="5" Grid.Column="2" FontFamily='Georgia' FontSize="12" VerticalAlignment="Center"  HorizontalAlignment="Center" Margin="0,5,0,10" Name="myTextBlock2">Destination</TextBlock>
      <TextBlock Grid.Row="5" Grid.Column="3" FontFamily='Georgia' FontSize="12" VerticalAlignment="Center"  HorizontalAlignment="Center" Margin="0,5,0,0" Name="myTextBlock3">Block Move</TextBlock>
   </Grid>
</UserControl>
