<Window x:Class="PleasantvilleGame.RuleListingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PleasantvilleGame"
        mc:Ignorable="d"
        Topmost="True"         
        Name ="myDialogRuleListing"
        Title="Rule Listing" Height="900" Width="450" MinWidth="450" MaxWidth="500" WindowStartupLocation="CenterScreen"
        Closed="Window_Closed">
   <ScrollViewer Name="myScrollViewer" VerticalScrollBarVisibility="Auto" Margin="0,0,0,0">
      <Grid Name="myGrid" >
         <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
         </Grid.RowDefinitions>
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
         </Grid.ColumnDefinitions>
         
      </Grid>
   </ScrollViewer>
</Window>
