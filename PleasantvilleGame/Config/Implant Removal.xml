<Table CellSpacing="2" BorderBrush="Black" BorderThickness="3">
	<Table.Columns>
		<TableColumn Width='80'/>
		<TableColumn Width='660'/>
	</Table.Columns>
	<TableRowGroup>
		<TableRow  FontSize='18' >
			<TableCell ColumnSpan='2' TextAlignment='Center' BorderBrush='Black' BorderThickness='1'>
				<Paragraph>
					<LineBreak/>
					IMPLANT REMOVAL TABLE
					<LineBreak/>
				</Paragraph>
			</TableCell>
		</TableRow>
	</TableRowGroup>
	<TableRowGroup>
		<TableRow  FontSize='12' Background='BurlyWood'>
			<TableCell BorderBrush='Black' BorderThickness='1'>
				<Paragraph>
					<Bold>
						<Run Text='Dice Roll'></Run>
					</Bold>
				</Paragraph>
			</TableCell>
			<TableCell BorderBrush='Black' BorderThickness='1'>
				<Paragraph>
					<Bold>
						<Run Text='Result'></Run>
					</Bold>
				</Paragraph>
			</TableCell>
		</TableRow>
	</TableRowGroup>
	<TableRowGroup>
		<TableRow  FontSize='12' >
			<TableCell BorderBrush='Black' BorderThickness='1'>
				<Paragraph>
					<Run Text='2-3'></Run>
				</Paragraph>
			</TableCell>
			<TableCell BorderBrush='Black' BorderThickness='1' TextAlignment='Left'>
				<Paragraph>
					<Bold>
						<Run Text='Implant Explodes!'/>
					</Bold>
					<Run Text=' The victim and the townsperson trying to remove the implant are killed and removed from play.'></Run>
				</Paragraph>
			</TableCell>
		</TableRow>
		<TableRow  FontSize='12' Background='BurlyWood'>
			<TableCell BorderBrush='Black' BorderThickness='1' >
				<Paragraph>
					<Run Text='4-6'></Run>
				</Paragraph>
			</TableCell>
			<TableCell BorderBrush='Black' BorderThickness='1' TextAlignment='Left'>
				<Paragraph>
					<Bold>
						<Run Text='Implant too tightly attached. '/>
					</Bold>
					<Run Text=' It cannot be removed this turn, but another try may be made next turn during the post-combat activity phase.'></Run>
				</Paragraph>
			</TableCell>
		</TableRow>
		<TableRow  FontSize='12' >
			<TableCell BorderBrush='Black' BorderThickness='1'>
				<Paragraph>
					<Run Text='7-10'></Run>
				</Paragraph>
			</TableCell>
			<TableCell BorderBrush='Black' BorderThickness='1' TextAlignment='Left'>
				<Paragraph>
					<Bold>
						<Run Text='Implant Removed! '/>
					</Bold>
					<Run Text=' However, it immediately disintegrates and cannot be used as evidence'></Run>
				</Paragraph>
			</TableCell>
		</TableRow>
      <TableRow  FontSize='12' Background='BurlyWood'>
         <TableCell BorderBrush='Black' BorderThickness='1' >
            <Paragraph>
               <Run Text='11-12'></Run>
            </Paragraph>
         </TableCell>
         <TableCell BorderBrush='Black' BorderThickness='1' TextAlignment='Left'>
            <Paragraph>
               <Bold>
                  <Run Text='Implant removed intact! '/>
               </Bold>
               <Run Text=' Evidence of Aliens is obtained.'></Run>
            </Paragraph>
         </TableCell>
      </TableRow>
	</TableRowGroup>
</Table>
